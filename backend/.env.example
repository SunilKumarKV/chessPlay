NODE_ENV=development
PORT=3001

# Local development database only. Use a Render secret value for production.
MONGODB_URI=mongodb://127.0.0.1:27017/chessplay

# Required in every environment. Use a random value with at least 32 characters.
JWT_SECRET=replace-with-a-random-32-plus-character-secret

# Comma-separated frontend origins allowed by CORS and Socket.IO.
# Vercel example: https://your-project.vercel.app
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: require x-health-secret for /health checks.
HEALTH_SECRET=

# Optional: required only when Google Sign-In is enabled on the frontend.
GOOGLE_CLIENT_ID=

# Optional: comma-separated words blocked from multiplayer chat.
BLOCKED_WORDS=
